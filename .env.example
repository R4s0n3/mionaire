# Public origin that serves both the Mionaire REST API and Auth.js routes.
# Locally this is the Express server. In production, prefer the web origin with
# /api/v1/* and /auth/* reverse-proxied to Express (or a same-site API origin).
# This value is embedded into the browser bundle at build time.
NEXT_PUBLIC_API_BASE_URL="http://localhost:3001"

# Optional. Leave empty to disable the Google AdSense script.
NEXT_PUBLIC_ADSENSE_CLIENT_ID=""
